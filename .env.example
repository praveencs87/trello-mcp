# Trello API Credentials
# Get these from: https://trello.com/app-key

# Your Trello API Key (required)
TRELLO_API_KEY=your_trello_api_key_here

# Your Trello API Token (required)
# Click the "Token" link on the same page as your API key to generate this
TRELLO_API_TOKEN=your_trello_api_token_here

# Optional: Port for HTTP transport (defaults to stdio if not set)
# PORT=8000

# Optional: Debug mode (set to 'true' to enable debug logging)
# DEBUG=true
